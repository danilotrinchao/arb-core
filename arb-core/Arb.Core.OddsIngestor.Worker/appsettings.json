{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Streams": {
    "OddsTicks": "odds:ticks",
    "OrderIntents": "orders:intents",
    "ExecutionReports": "orders:reports"
  },
  "FootballCatalogRedis": {
    "SnapshotKey": "pm:football:quote-eligible:current",
    "StreamKey": "pm:events:catalog",
    "UpdatedEventType": "football.catalog.updated",
    "ReadCount": 10,
    "BlockMilliseconds": 3000,
    "ConnectTimeoutMs": 5000,
    "SyncTimeoutMs": 15000,
    "AsyncTimeoutMs": 15000,
    "KeepAliveSeconds": 30
  },
  "PolymarketObservation": {
    "StreamName": "polymarket:observed:ticks",
    "Enabled": true
  },
  "TheOddsApi": {
    "BaseUrl": "https://api.the-odds-api.com",
    "SportKeys": [ "soccer_brazil_campeonato" ],
    "Markets": [ "h2h" ],
    "Bookmakers": [ "pinnacle", "betfair", "matchbook", "betonlineag" ],
    "OddsFormat": "decimal",
    "DateFormat": "iso"
  },
  "OddsIngestor": {
    "DailyCreditBudget": 10,
    "EnableDedup": true,
    "IdleLoopDelaySeconds": 30
  }
}
