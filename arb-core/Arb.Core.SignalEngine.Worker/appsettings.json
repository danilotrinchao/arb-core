{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Streams": {
    "OddsTicks": "odds:ticks",
    "OrderIntents": "orders:intents",
    "ExecutionReports": "orders:reports"
  },
  "SignalEngine": {
    "MinMovementPercent": 2.0,
    "DefaultStake": 10.0,
    "StrategyName": "SharpReferenceMovementV1",
    "Venue": "paper",
    "RequireShorteningOdds": true,
    "MinSourcesForReference": 2,
    "MaxSourceStalenessMinutes": 120,
    "LongHorizonMinutes": 2880,
    "RestrictedLeagueKeysCsv": "soccer_spain_la_liga,soccer_france_ligue_one",
    "PreferredLeagueKeysCsv": "soccer_brazil_campeonato,soccer_uefa_champs_league",
    "ScoreBonusForNonPositiveDelta": 10,
    "ScorePenaltyForLongHorizon": 10,
    "ScorePenaltyForRestrictedLeague": 10,
    "EnableShadowSignalPolicy": true,
    "ShadowMinSignalQualityScore": 55.0,
    "ShadowMaxPositiveDeltaGlobal": 0.03,
    "ShadowMaxPositiveDeltaLongHorizon": 0.01,
    "ShadowMinInitialEdgeGlobal": 0.02,
    "ShadowMinInitialEdgeLongHorizon": 0.03,
    "ShadowPolicyVersion": "SignalShadowPolicyV1"
  },
  "PolymarketObservedSignal": {
    "Enabled": true,
    "InputStreamName": "polymarket:observed:ticks",
    "OutputStreamName": "polymarket:orders:intents",
    "MinMovementPct": 0.25,
    "MinSources": 2,
    "SignalCooldownSeconds": 300,
    "StartFromLatest": true,
    "ReadCount": 50,
    "BlockMilliseconds": 500
  }
}
