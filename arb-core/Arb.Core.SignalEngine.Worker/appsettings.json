{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Redis": {
    "Connection": "localhost:6379"
  },
  "Postgres": {
    "Connection": "Host=localhost;Port=5432;Database=arb;Username=postgres;Password=1234"
  },
  "Streams": {
    "OddsTicks": "odds:ticks",
    "OrderIntents": "orders:intents",
    "ExecutionReports": "orders:reports"
  },
  "SignalEngine": {
    "MinMovementPercent": 2.0,
    "DefaultStake": 10.0,
    "StrategyName": "SharpReferenceMovementV1",
    "Venue": "paper",
    "RequireShorteningOdds": true,
    "MinSourcesForReference": 2,
    "MaxSourceStalenessMinutes": 120
  },
  "PolymarketObservedSignal": {
    "Enabled": true,
    "InputStreamName": "polymarket:observed:ticks",
    "OutputStreamName": "polymarket:orders:intents",
    "MinMovementPct": 1.5,
    "MinSources": 2,
    "SignalCooldownSeconds": 300,
    "StartFromLatest": true,
    "ReadCount": 50,
    "BlockMilliseconds": 500
  }
}
